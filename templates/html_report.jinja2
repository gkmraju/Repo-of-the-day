<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ repo.owner }}/{{ repo.name }} · Repo of the Day</title>
  <style>
    :root {
      --bg:     #0d1117;
      --card:   #161b22;
      --card2:  #21262d;
      --border: #30363d;
      --text:   #e6edf3;
      --muted:  #8b949e;
      --accent: #58a6ff;
      --green:  #3fb950;
      --yellow: #d29922;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      background: var(--bg);
      color: var(--text);
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      font-size: 14px;
      line-height: 1.55;
      padding: 16px;
      max-width: 480px;
      margin: 0 auto;
    }
    a { color: var(--accent); text-decoration: none; }

    /* ── Top label ── */
    .label {
      display: inline-block;
      background: var(--accent);
      color: #000;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.12em;
      padding: 3px 10px;
      border-radius: 20px;
      margin-bottom: 12px;
    }

    /* ── Card ── */
    .card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 14px 16px;
      margin-bottom: 8px;
    }

    /* ── Repo identity ── */
    .repo-name {
      font-size: 1.2rem;
      font-weight: 700;
      line-height: 1.2;
      margin-bottom: 6px;
    }
    .repo-name .owner { color: var(--muted); font-weight: 400; }

    .desc {
      color: var(--muted);
      font-size: 0.85rem;
      margin-bottom: 10px;
    }

    /* ── Stats row ── */
    .stats {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      font-size: 0.82rem;
      margin-bottom: 10px;
    }
    .stat { display: flex; align-items: center; gap: 4px; }
    .stat b { color: var(--text); }
    .yellow { color: var(--yellow); }

    /* ── Tags ── */
    .tags { display: flex; flex-wrap: wrap; gap: 5px; margin-bottom: 10px; }
    .tag {
      background: var(--card2);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 1px 9px;
      font-size: 0.75rem;
      color: var(--accent);
    }

    /* ── Meta line ── */
    .meta {
      font-size: 0.78rem;
      color: var(--muted);
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }

    /* ── Score badge (top-right in header card) ── */
    .score-badge {
      float: right;
      background: linear-gradient(135deg, var(--accent), var(--green));
      color: #000;
      font-size: 0.7rem;
      font-weight: 700;
      padding: 2px 9px;
      border-radius: 20px;
      margin-left: 8px;
    }

    /* ── Section title ── */
    .stitle {
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 6px;
    }

    /* ── Body text ── */
    .body { font-size: 0.85rem; color: var(--muted); }

    /* ── Feature list ── */
    .features { list-style: none; }
    .features li { font-size: 0.85rem; color: var(--muted); padding: 2px 0; }
    .features li::before { content: "▸ "; color: var(--accent); }

    /* ── CTA button ── */
    .cta {
      display: block;
      background: var(--accent);
      color: #000 !important;
      font-weight: 700;
      font-size: 0.9rem;
      text-align: center;
      padding: 11px;
      border-radius: 8px;
      margin-top: 8px;
    }
    .cta-ghost {
      display: block;
      border: 1px solid var(--border);
      color: var(--text) !important;
      font-size: 0.85rem;
      text-align: center;
      padding: 9px;
      border-radius: 8px;
      margin-top: 6px;
    }

    /* ── Footer ── */
    .footer {
      text-align: center;
      color: var(--muted);
      font-size: 0.75rem;
      padding: 14px 0 6px;
      border-top: 1px solid var(--border);
      margin-top: 12px;
    }
    .one-liner {
      font-size: 0.82rem;
      font-style: italic;
      color: var(--accent);
      text-align: center;
      margin: 10px 0 4px;
    }
  </style>
</head>
<body>

  <div class="label">🚀 REPO OF THE DAY &nbsp;·&nbsp; {{ now }}</div>

  <!-- ── Identity card ────────────────────────────────────────── -->
  <div class="card">
    <span class="score-badge">{{ "%.0f"|format(repo.score) }}/100</span>
    <div class="repo-name">
      <span class="owner">{{ repo.owner }}/</span>{{ repo.name }}
    </div>
    <div class="desc">{{ repo.description }}</div>

    <div class="stats">
      <div class="stat yellow"><b>⭐ {{ repo.stars_formatted }}</b> stars</div>
      <div class="stat"><b>🍴 {{ repo.forks_formatted }}</b> forks</div>
      {% if repo.language %}<div class="stat">💻 <b>{{ repo.language }}</b></div>{% endif %}
      {% if repo.contributors_count %}<div class="stat">👥 <b>{{ repo.contributors_count }}</b> contributors</div>{% endif %}
    </div>

    {% if repo.topics %}
    <div class="tags">
      {% for t in repo.topics[:6] %}<span class="tag">#{{ t }}</span>{% endfor %}
    </div>
    {% endif %}

    <div class="meta" style="margin-top:8px;">
      {% if repo.license %}<span>📜 {{ repo.license }}</span>{% endif %}
      {% if repo.latest_release %}<span>🏷️ {{ repo.latest_release }}</span>{% endif %}
      <span>📅 Updated {{ repo.updated_friendly }}</span>
    </div>
  </div>

  <!-- ── About ──────────────────────────────────────────────────── -->
  <div class="card">
    <div class="stitle">About</div>
    <div class="body">{{ repo.what_is | strip_md }}</div>
  </div>

  <!-- ── Key Features ──────────────────────────────────────────── -->
  {% if repo.features %}
  <div class="card">
    <div class="stitle">Key Features</div>
    <ul class="features">
      {% for f in repo.features[:5] %}
      <li>{{ f | strip_md }}</li>
      {% endfor %}
    </ul>
  </div>
  {% endif %}

  <!-- ── Why Use It ────────────────────────────────────────────── -->
  {% if repo.why_useful %}
  <div class="card">
    <div class="stitle">Why Use It</div>
    <div class="body">{{ repo.why_useful | strip_md }}</div>
  </div>
  {% endif %}

  <!-- ── Actions ───────────────────────────────────────────────── -->
  <a class="cta" href="{{ repo.url }}" target="_blank">🔗 View on GitHub →</a>
  {% if repo.homepage %}
  <a class="cta-ghost" href="{{ repo.homepage }}" target="_blank">🌐 Homepage →</a>
  {% endif %}

  {% if repo.one_liner %}
  <div class="one-liner">{{ repo.one_liner | strip_md }}</div>
  {% endif %}

  <div class="footer">Repo Of The Day &nbsp;·&nbsp; {{ now }}</div>

</body>
</html>

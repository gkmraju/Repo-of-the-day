<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Repo of the Day — {{ repo.name }}</title>
  <style>
    :root {
      --bg:       #0d1117;
      --surface:  #161b22;
      --card:     #21262d;
      --border:   #30363d;
      --text:     #e6edf3;
      --muted:    #8b949e;
      --accent:   #58a6ff;
      --green:    #3fb950;
      --yellow:   #d29922;
      --red:      #f85149;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      background: var(--bg);
      color: var(--text);
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      line-height: 1.6;
      padding: 2rem;
    }
    a { color: var(--accent); text-decoration: none; }
    a:hover { text-decoration: underline; }

    .container { max-width: 900px; margin: 0 auto; }

    /* Header */
    .badge-top {
      background: var(--accent);
      color: #000;
      font-weight: 700;
      font-size: 0.75rem;
      letter-spacing: 0.1em;
      padding: 4px 12px;
      border-radius: 20px;
      display: inline-block;
      margin-bottom: 1.5rem;
    }
    .repo-header {
      border: 1px solid var(--border);
      background: var(--surface);
      border-radius: 12px;
      padding: 2rem;
      margin-bottom: 1.5rem;
    }
    .repo-title { font-size: 2rem; font-weight: 700; margin-bottom: 0.5rem; }
    .repo-title .owner { color: var(--muted); font-weight: 400; }
    .description { color: var(--muted); font-size: 1.05rem; margin-bottom: 1rem; }
    .meta-row { display: flex; flex-wrap: wrap; gap: 1rem; margin-bottom: 1rem; }
    .meta-item { display: flex; align-items: center; gap: 0.4rem; font-size: 0.9rem; color: var(--muted); }
    .meta-item strong { color: var(--text); }
    .topics { display: flex; flex-wrap: wrap; gap: 0.5rem; }
    .topic-pill {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 2px 10px;
      font-size: 0.8rem;
      color: var(--accent);
    }

    /* Stats grid */
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
      margin-bottom: 1.5rem;
    }
    .stat-card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 1rem;
      text-align: center;
    }
    .stat-value { font-size: 1.5rem; font-weight: 700; color: var(--text); }
    .stat-label { font-size: 0.8rem; color: var(--muted); }
    .stars-value { color: var(--yellow); }

    /* Score bar */
    .score-section {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 1rem 1.5rem;
      margin-bottom: 1.5rem;
      display: flex;
      align-items: center;
      gap: 1rem;
    }
    .score-label { font-weight: 600; min-width: 120px; }
    .score-bar {
      flex: 1;
      height: 10px;
      background: var(--border);
      border-radius: 5px;
      overflow: hidden;
    }
    .score-fill {
      height: 100%;
      border-radius: 5px;
      background: linear-gradient(90deg, var(--accent), var(--green));
      width: {{ repo.score }}%;
      transition: width 0.5s;
    }
    .score-num { font-weight: 700; color: var(--accent); min-width: 60px; text-align: right; }

    /* Content sections */
    .section {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 1.5rem;
      margin-bottom: 1rem;
    }
    .section h2 {
      font-size: 1rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--accent);
      margin-bottom: 1rem;
      padding-bottom: 0.5rem;
      border-bottom: 1px solid var(--border);
    }
    .section p { color: var(--muted); }
    .bullet-list { list-style: none; }
    .bullet-list li { padding: 0.25rem 0; color: var(--muted); }
    .bullet-list li::before { content: "▸ "; color: var(--accent); }

    /* Code block */
    pre {
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 1rem;
      overflow-x: auto;
      font-family: "SFMono-Regular", Consolas, "Liberation Mono", monospace;
      font-size: 0.85rem;
      color: var(--green);
      margin: 0.5rem 0;
    }

    /* Similar projects */
    .similar-grid { display: flex; flex-direction: column; gap: 0.5rem; }
    .similar-item {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 0.75rem 1rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .similar-item a { font-weight: 600; }
    .similar-desc { color: var(--muted); font-size: 0.85rem; }

    /* Footer */
    .footer {
      text-align: center;
      color: var(--muted);
      font-size: 0.85rem;
      padding: 2rem 0 1rem;
      border-top: 1px solid var(--border);
      margin-top: 2rem;
    }
    .one-liner {
      background: linear-gradient(135deg, var(--accent), var(--green));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      font-size: 1.2rem;
      font-weight: 700;
      text-align: center;
      margin: 1.5rem 0;
    }

    @media (max-width: 600px) {
      .stats-grid { grid-template-columns: repeat(2, 1fr); }
    }
  </style>
</head>
<body>
<div class="container">
  <div class="badge-top">🚀 REPO OF THE DAY — {{ now }}</div>

  <!-- Header -->
  <div class="repo-header">
    <div class="repo-title">
      <span class="owner">{{ repo.owner }}/</span>{{ repo.name }}
    </div>
    <div class="description">{{ repo.description }}</div>
    <div class="meta-row">
      {% if repo.language %}
      <div class="meta-item">💻 <strong>{{ repo.language }}</strong></div>
      {% endif %}
      {% if repo.license %}
      <div class="meta-item">📜 <strong>{{ repo.license }}</strong></div>
      {% endif %}
      <div class="meta-item">📅 Updated: <strong>{{ repo.updated_friendly }}</strong></div>
      {% if repo.latest_release %}
      <div class="meta-item">🏷️ <strong>{{ repo.latest_release }}</strong></div>
      {% endif %}
    </div>
    {% if repo.topics %}
    <div class="topics">
      {% for t in repo.topics %}
      <span class="topic-pill">#{{ t }}</span>
      {% endfor %}
    </div>
    {% endif %}
  </div>

  <!-- Stats -->
  <div class="stats-grid">
    <div class="stat-card">
      <div class="stat-value stars-value">{{ repo.stars_formatted }}</div>
      <div class="stat-label">⭐ Stars</div>
    </div>
    <div class="stat-card">
      <div class="stat-value">{{ repo.forks_formatted }}</div>
      <div class="stat-label">🍴 Forks</div>
    </div>
    <div class="stat-card">
      <div class="stat-value">{{ repo.contributors_count or '?' }}</div>
      <div class="stat-label">👥 Contributors</div>
    </div>
    <div class="stat-card">
      <div class="stat-value">{{ repo.open_issues or 0 }}</div>
      <div class="stat-label">🐛 Open Issues</div>
    </div>
  </div>

  <!-- Score -->
  <div class="score-section">
    <div class="score-label">🏆 Composite Score</div>
    <div class="score-bar"><div class="score-fill"></div></div>
    <div class="score-num">{{ "%.1f" | format(repo.score) }}/100</div>
  </div>

  <!-- What is it -->
  <div class="section">
    <h2>📖 What is it?</h2>
    <p>{{ repo.what_is }}</p>
  </div>

  <!-- Why useful -->
  <div class="section">
    <h2>❓ Why is it useful?</h2>
    <p style="white-space: pre-line;">{{ repo.why_useful }}</p>
  </div>

  <!-- Features -->
  {% if repo.features %}
  <div class="section">
    <h2>✨ Key Features</h2>
    <ul class="bullet-list">
      {% for f in repo.features %}
      <li>{{ f }}</li>
      {% endfor %}
    </ul>
  </div>
  {% endif %}

  <!-- How it works -->
  {% if repo.how_it_works %}
  <div class="section">
    <h2>⚙️ How it Works</h2>
    <p>{{ repo.how_it_works }}</p>
  </div>
  {% endif %}

  <!-- Installation -->
  {% if repo.installation %}
  <div class="section">
    <h2>📦 Installation</h2>
    <pre>{{ repo.installation }}</pre>
  </div>
  {% endif %}

  <!-- Example -->
  {% if repo.quick_example %}
  <div class="section">
    <h2>💻 Quick Example</h2>
    <pre>{{ repo.quick_example }}</pre>
  </div>
  {% endif %}

  <!-- Tech Stack -->
  {% if repo.tech_stack %}
  <div class="section">
    <h2>🛠 Tech Stack</h2>
    <ul class="bullet-list">
      {% for item in repo.tech_stack %}
      <li>{{ item }}</li>
      {% endfor %}
    </ul>
  </div>
  {% endif %}

  <!-- Who should use it -->
  {% if repo.audience %}
  <div class="section">
    <h2>👥 Who Should Use It?</h2>
    <ul class="bullet-list">
      {% for a in repo.audience %}
      <li>{{ a }}</li>
      {% endfor %}
    </ul>
  </div>
  {% endif %}

  <!-- Pros & Cons -->
  <div class="section">
    <h2>✅ Pros &amp; ⚠️ Considerations</h2>
    <ul class="bullet-list">
      {% for p in repo.pros %}<li>✅ {{ p }}</li>{% endfor %}
      {% for c in repo.cons %}<li>⚠️ {{ c }}</li>{% endfor %}
    </ul>
  </div>

  <!-- Learnings -->
  {% if repo.learnings %}
  <div class="section">
    <h2>🎓 What Can You Learn?</h2>
    <ul class="bullet-list">
      {% for l in repo.learnings %}
      <li>{{ l }}</li>
      {% endfor %}
    </ul>
  </div>
  {% endif %}

  <!-- Similar Projects -->
  {% if repo.similar_projects %}
  <div class="section">
    <h2>🔄 Similar Projects</h2>
    <div class="similar-grid">
      {% for proj in repo.similar_projects %}
      <div class="similar-item">
        <a href="https://github.com/{{ proj.name }}" target="_blank">{{ proj.name }}</a>
        <span class="similar-desc">{{ proj.desc }}</span>
      </div>
      {% endfor %}
    </div>
  </div>
  {% endif %}

  <!-- One-liner -->
  <div class="one-liner">{{ repo.one_liner }}</div>

  <!-- CTA -->
  <div style="text-align:center; margin-bottom: 2rem;">
    <a href="{{ repo.url }}" target="_blank"
       style="background:var(--accent);color:#000;font-weight:700;padding:0.75rem 2rem;border-radius:8px;display:inline-block;">
      🔗 View on GitHub
    </a>
    {% if repo.homepage %}
    &nbsp;
    <a href="{{ repo.homepage }}" target="_blank"
       style="background:var(--card);border:1px solid var(--border);color:var(--text);font-weight:600;padding:0.75rem 2rem;border-radius:8px;display:inline-block;">
      🌐 Homepage
    </a>
    {% endif %}
  </div>

  <div class="footer">
    Generated by <strong>Repo Of The Day</strong> · {{ now }} · 100% Free &amp; Open Source
  </div>
</div>
</body>
</html>

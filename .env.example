# ─────────────────────────────────────────────────────────────
# REPO OF THE DAY — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────

# GitHub Personal Access Token (classic)
# Scopes needed: public_repo (read-only is fine)
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here

# Telegram Bot Token
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ

# Telegram Channel/Group Chat ID
# For a channel: @yourchannel  or  -100xxxxxxxxxx
# For a group: -xxxxxxxxxx
TELEGRAM_CHAT_ID=@your_channel_or_chat_id

# ─────────────────────────────────────────────────────────────
# Optional overrides (defaults shown)
# ─────────────────────────────────────────────────────────────

# Minimum stars for a repo to be considered
# MIN_STARS=300

# Scoring weights (must sum to 1.0)
# WEIGHT_STARS=0.25
# WEIGHT_RECENT_ACTIVITY=0.20
# WEIGHT_GROWTH_POTENTIAL=0.10
# WEIGHT_README_QUALITY=0.10
# WEIGHT_CONTRIBUTORS=0.10
# WEIGHT_ISSUE_ACTIVITY=0.05
# WEIGHT_DOCUMENTATION=0.10
# WEIGHT_POPULARITY=0.05
# WEIGHT_COMMUNITY=0.05

# Dry-run: generate content but do NOT post to Telegram
# DRY_RUN=false
